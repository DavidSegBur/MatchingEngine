<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: white;"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="group20tup.matchingengine.controller.PantallaCargaController">

   <VBox alignment="CENTER"
         spacing="20"
         maxWidth="800">

      <ImageView fx:id="logoImageView"
                 fitWidth="266"
                 preserveRatio="true"
                 pickOnBounds="true">
          <image><Image url="@../images/Logo.png" /></image>
      </ImageView>

      <!-- Rectángulo negro → "BIENVENIDO A" en blanco -->
      <StackPane fx:id="stackPaneBienvenido"
                 prefHeight="51"
                 style="-fx-background-color: black;
                        -fx-background-radius: 5;
                        -fx-padding: 0 20;">

          <Label style="-fx-text-fill: white;
                        -fx-font-family: 'Arial Black';
                        -fx-font-size: 30px;
                        -fx-font-weight: bold;"
                 text="BIENVENIDO A" />
      </StackPane>

      <!-- "MATCHING ENGINE" en fuente Stencil -->
      <Label fx:id="matchingEngineLabel"
             style="-fx-text-fill: black;
                    -fx-font-family: 'Stencil';
                    -fx-font-size: 60px;
                    -fx-font-weight: bold;"
             text="&quot;MATCHING ENGINE&quot;" />

      <!-- Subtítulo -->
      <Label fx:id="subtituloLabel"
             text="&quot;Te conectamos con tu Destino...&quot;">
          <font><Font name="Calibri Bold" size="31.0" /></font>
      </Label>

      <!-- Botón negro con texto blanco -->
      <Button fx:id="btnAccion0"
              alignment="CENTER"
              onAction="#onIniciarClick"
              style="-fx-background-color: black;
                     -fx-background-radius: 16;
                     -fx-padding: 10 30;"
              text="I N I C I A R"
              textFill="WHITE">
          <font><Font name="Calibri Bold" size="31.0" /></font>
      </Button>

   </VBox>
</StackPane>
