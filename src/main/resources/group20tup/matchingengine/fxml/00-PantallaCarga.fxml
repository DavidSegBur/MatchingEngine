<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800" 
            prefWidth="1200" 
            style="-fx-background-color: white;" 
            xmlns="http://javafx.com/javafx/26" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="group20tup.matchingengine.controller.PantallaCargaController"> 

  <ImageView  fx:id="logoImageView" 
              fitHeight="253.0" 
              fitWidth="266.0" 
              layoutX="482.0" 
              layoutY="100.0" 
              pickOnBounds="true" 
              preserveRatio="true" 
              AnchorPane.leftAnchor="482.0">
      <image><Image url="@Images/Logo.png" /></image>
  </ImageView>

  <!-- ① Rectángulo negro → "BIENVENIDO A" en blanco -->
  <StackPane fx:id="stackPaneBienvenido" 
             layoutX="279.0" 
             layoutY="410.0" 
             maxWidth="832.0" 
             prefHeight="51.0" 
             prefWidth="707.0" 
             style="-fx-background-color: black; 
                    -fx-background-radius: 5;" 
             AnchorPane.leftAnchor="279.0" 
             AnchorPane.rightAnchor="279.0">

      <children>
           <Label style="-fx-text-fill:   white;                             
                         -fx-font-family: 'Arial Black';                                                                              
                         -fx-font-size:   30px;                                                                              
                         -fx-font-weight: bold;" 
                  text="BIENVENIDO A" />

      </children>
  </StackPane>

  <!-- ② "MATCHING ENGINE" en fuente Stencil -->
  <Label fx:id="matchingEngineLabel" 
         layoutX="309.0" 
         layoutY="468.0" 
         prefHeight="74.0" 
         prefWidth="582.0" 
         style="-fx-text-fill:   black;                                                         
                -fx-font-family: 'Stencil';                                                         
                -fx-font-size:   60px;                                                         
                -fx-font-weight: bold;" 
         text="&quot;MATCHING ENGINE&quot;" 
         AnchorPane.leftAnchor="309.0" 
         AnchorPane.rightAnchor="309.0" />

  <!-- ③ Subtítulo en Arial Black -->
  <Label fx:id="subtituloLabel" 
         alignment="CENTER" 
         layoutX="375.0" 
         layoutY="556.0" 
         prefHeight="36.0" 
         prefWidth="449.0" 
         text="&quot;Te conectamos con tu Destino...&quot;" 
         AnchorPane.leftAnchor="375.5" 
         AnchorPane.rightAnchor="375.5">
      <font><Font name="Calibri Bold" size="31.0" /></font>
  </Label>

  <!-- ④ Botón negro con texto blanco -->   
  <Button fx:id="btnAccion0" 
          alignment="CENTER" 
          layoutX="473.0" 
          layoutY="633.0" 
          onAction="#onIniciarClick" 
          prefHeight="20.0" 
          prefWidth="254.0" 
          style="-fx-background-color: black;                   
                 -fx-background-radius: 16;" 
          text="I N I C I A R" 
          textFill="WHITE" 
          AnchorPane.leftAnchor="473.0" 
          AnchorPane.rightAnchor="473.0">
      <font><Font name="Calibri Bold" size="31.0" /></font>
  </Button>
</AnchorPane>
