<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="BasePane"
            prefHeight="130.0" 
            prefWidth="320.0" 
            xmlns="http://javafx.com/javafx/26" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="group20tup.matchingengine.controller.VehiculoDisponibleController"> 

   <children>
      <!--Imagen del Vehículo--> 
      <ImageView fx:id="vehiculoImageView" 
                 fitHeight="39.0" 
                 fitWidth="82.0" 
                 layoutX="14.0" 
                 layoutY="48.0" 
                 pickOnBounds="true" 
                 preserveRatio="true"> 
           <image><Image url="@Images/Logo.png" /></image>
      </ImageView>

      <AnchorPane layoutX="6.0" 
                  layoutY="8.0" 
                  prefHeight="19.0" 
                  prefWidth="310.0" 
                  style="-fx-background-color: black;">

         <children>
            <HBox prefHeight="17.0" 
                  prefWidth="310.0">

               <children>
                  <Label alignment="CENTER_RIGHT" 
                         prefHeight="17.0" 
                         prefWidth="172.0" 
                         text="VEHICULO PATENTE :  " 
                         textFill="WHITE">
                     <font><Font name="Calibri Bold" size="12.0" /></font>
                  </Label>

                  <Label fx:id="vehiculoPatenteCatch"
                         prefHeight="17.0" 
                         prefWidth="167.0" 
                         text="" 
                         textFill="WHITE">
                     <font><Font name="Calibri Bold" size="12.0" /></font>
                  </Label>
               </children>
            </HBox>
         </children>
      </AnchorPane>

      <VBox layoutX="108.0" 
            layoutY="35.0" 
            prefHeight="60.0" 
            prefWidth="206.0" 
            style="-fx-border-color: black;">

         <children>
            <VBox prefHeight="200.0" 
                  prefWidth="100.0">

               <children>
                  <HBox prefHeight="100.0" 
                        prefWidth="200.0">

                     <children>
                        <Label prefHeight="29.0" 
                               prefWidth="208.0" 
                               text=" ESTADO :    DISPONIBLE">
                           <font><Font name="Calibri Bold" size="15.0" /></font>
                        </Label>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox prefHeight="200.0" 
                  prefWidth="100.0">

               <children>
                  <Separator prefHeight="1.0" 
                             prefWidth="209.0" />

                  <HBox prefHeight="100.0" 
                        prefWidth="200.0">

                     <children>
                        <Label alignment="CENTER" 
                               prefHeight="26.0" 
                               prefWidth="122.0" 
                               text="POSICIÓN :">
                           <font><Font name="Calibri Bold" size="15.0" /></font>
                        </Label>

                        <Label fx:id="vehiculoPosicionCatch"
                               prefHeight="26.0" 
                               prefWidth="176.0" 
                               text="">
                           <font><Font name="Calibri Bold" size="15.0" /></font>
                        </Label>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>

      <AnchorPane layoutX="6.0" 
                  layoutY="102.0" 
                  prefHeight="19.0" 
                  prefWidth="310.0" 
                  style="-fx-background-color: grey;">

         <children>
            <HBox prefHeight="17.0" 
                  prefWidth="310.0">

               <children>
                  <Label alignment="CENTER" 
                         prefHeight="17.0" 
                         prefWidth="76.0" 
                         text="UBICACIÓN:" 
                         textFill="WHITE">
                     <font><Font name="Calibri Bold" size="12.0" /></font>
                  </Label>

                  <Label fx:id="nombreCalleCath"
                         prefHeight="17.0" 
                         prefWidth="250.0" 
                         text="" 
                         textFill="WHITE">
                     <font><Font name="Calibri Bold" size="12.0" /></font>
                  </Label>
               </children>
            </HBox>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
